APP_NAME="Appreciation Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=appreciation_platform
DB_USERNAME=root
DB_PASSWORD=

# Cache & Sessions
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@company.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# LDAP / Active Directory Configuration
LDAP_HOST=ldap.company.com
LDAP_PORT=389
LDAP_BASE_DN=dc=company,dc=com
LDAP_USERNAME=cn=ldap-reader,dc=company,dc=com
LDAP_PASSWORD=secret
LDAP_TIMEOUT=5
LDAP_SSL=false
LDAP_TLS=false
LDAP_LOGGING=false

# LDAP Search Configuration
LDAP_USER_SEARCH_BASE=ou=Users,dc=company,dc=com
LDAP_ADMIN_GROUP=CN=IT-Admins,OU=Groups,DC=company,DC=com

# JWT
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=1440

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# Platform
DEFAULT_LANGUAGE=en
DEFAULT_APPRECIATION_LIMIT=10
PLATFORM_NAME_EN="Appreciation Platform"
PLATFORM_NAME_AR="منصة التقدير"
