APP_NAME="Appreciation Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Must match wherever the Vue app is served from (used in CORS allowed_origins)
FRONTEND_URL=http://localhost:5173

# Comma-separated list of domains allowed to send cookies (Sanctum stateful auth)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174,127.0.0.1:5173,localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=appreciation_platform
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache, Sessions & Queues ────────────────────────────────────────────────
# Use "file" for cache — requires NO extra setup (no Redis, no DB table).
# Switch to "redis" or "database" when you have those services running.
CACHE_DRIVER=file
CACHE_STORE=file

# Use "database" for queue — runs from the DB (jobs table included in migrations).
# Switch to "redis" if you have Redis installed.
QUEUE_CONNECTION=database

# Use "file" or "cookie" for sessions on IIS without Redis.
SESSION_DRIVER=file
SESSION_LIFETIME=480

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

# ─── Redis (optional — only needed if CACHE_DRIVER=redis / QUEUE_CONNECTION=redis)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=your.smtp.server
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
# Set false for internal SMTP servers with self-signed / untrusted certificates.
MAIL_VERIFY_PEER=false
MAIL_FROM_ADDRESS="noreply@company.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── LDAP / Active Directory ─────────────────────────────────────────────────
# Leave LDAP_HOST blank to disable AD integration (local DB auth only).
LDAP_HOST=ldap.company.com
LDAP_PORT=389
LDAP_BASE_DN=dc=company,dc=com
LDAP_USERNAME=cn=ldap-reader,dc=company,dc=com
LDAP_PASSWORD=secret
LDAP_TIMEOUT=5
LDAP_SSL=false
LDAP_TLS=false
LDAP_LOGGING=false
LDAP_USER_SEARCH_BASE=ou=Users,dc=company,dc=com
LDAP_ADMIN_GROUP=CN=IT-Admins,OU=Groups,DC=company,DC=com

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# ─── External Employee Directory Search ──────────────────────────────────────
# Your corporate endpoint that searches all employees (reads from AD).
# Leave EMPLOYEE_SEARCH_URL blank to search the local DB only.
EMPLOYEE_SEARCH_URL=
# GET or POST — match what your endpoint accepts.
EMPLOYEE_SEARCH_METHOD=GET
# The parameter name carrying the term. GET → ?<field>=term, POST → {"<field>":term}.
# Common values: search, q, name, query, username.
EMPLOYEE_SEARCH_QUERY_FIELD=search
EMPLOYEE_SEARCH_TIMEOUT=10
# Set to false for internal HTTPS endpoints with self-signed/untrusted certs.
EMPLOYEE_SEARCH_VERIFY=false
# Optional bearer token / API key sent as "Authorization: Bearer <token>"
EMPLOYEE_SEARCH_TOKEN=
# JSON key that holds the array in the response (e.g. "data" or "results").
# Leave blank if the response IS the array itself.
EMPLOYEE_SEARCH_RESULTS_KEY=
# Diagnose with:  php artisan directory:test ahmed

# ─── Platform Defaults ───────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
DEFAULT_APPRECIATION_LIMIT=10
PLATFORM_NAME_EN="Appreciation Platform"
PLATFORM_NAME_AR="منصة التقدير"
